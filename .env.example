# ---------------------------------------------------------------------------
# AgendaMaster environment variables
# Copy this file to `.env` and fill in real values.  Never commit `.env`.
# See docs/GOOGLE_CLOUD_SETUP.md for the Google OAuth credentials.
# ---------------------------------------------------------------------------

# Database — local dev uses a file in the project root.
# In production this points outside the app dir: file:/var/www/data/prod.db
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth) session encryption secret. Generate with: npx auth secret
AUTH_SECRET=""

# Google OAuth 2.0 credentials (member login + Sheets/Drive/Gmail API access)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend — used for admin broadcasts & approval notifications.
# Leave RESEND_API_KEY blank in development to mock-log emails to logs/mock-emails.md
RESEND_API_KEY=""
RESEND_FROM_EMAIL="AgendaMaster <info@coquitlamgavel.com>"

# Seed script — password for the bootstrap admin account (coquitlamgavel@gmail.com).
# If unset, the admin seed step is skipped.
SEED_ADMIN_PASSWORD=""

# Cron archival endpoint protection (production). Bearer token for /api/cron/archive.
CRON_SECRET=""
